---
---

<canvas id="starfield" class="absolute inset-0 w-full h-full"></canvas>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  class Star {
    x = 0;
    y = 0;
    size = 0;
    opacity = 0;
    twinkleSpeed = 0;
    twinklePhase = 0;
    drift = 0;

    constructor() {
      this.reset();
    }

    reset() {
      this.x = Math.random() * canvas.width;
      this.y = Math.random() * canvas.height;
      this.size = Math.random() * 1.5 + 0.3;
      this.opacity = Math.random() * 0.6 + 0.1;
      this.twinkleSpeed = Math.random() * 0.02 + 0.005;
      this.twinklePhase = Math.random() * Math.PI * 2;
      this.drift = (Math.random() - 0.5) * 0.05;
    }

    update() {
      this.twinklePhase += this.twinkleSpeed;
      this.y += this.drift;
      if (this.y < -5 || this.y > canvas.height + 5) this.reset();
    }

    draw() {
      const twinkle = Math.sin(this.twinklePhase) * 0.3 + 0.7;
      const alpha = this.opacity * twinkle;

      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(201, 169, 110, ${alpha})`;
      ctx.fill();

      if (this.size > 1) {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size * 3, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(201, 169, 110, ${alpha * 0.08})`;
        ctx.fill();
      }
    }
  }

  interface ShootingStar {
    x: number;
    y: number;
    length: number;
    speed: number;
    angle: number;
    opacity: number;
    life: number;
  }

  const stars = Array.from({ length: 150 }, () => new Star());
  let shootingStar: ShootingStar | null = null;

  function maybeCreateShootingStar() {
    if (Math.random() > 0.002) return;
    shootingStar = {
      x: Math.random() * canvas.width * 0.8,
      y: Math.random() * canvas.height * 0.4,
      length: 80 + Math.random() * 60,
      speed: 4 + Math.random() * 3,
      angle: Math.PI / 4 + (Math.random() - 0.5) * 0.3,
      opacity: 1,
      life: 0,
    };
  }

  function drawShootingStar() {
    if (!shootingStar) return;
    const s = shootingStar;
    s.life += s.speed;
    s.opacity -= 0.015;

    if (s.opacity <= 0) {
      shootingStar = null;
      return;
    }

    const headX = s.x + Math.cos(s.angle) * s.life;
    const headY = s.y + Math.sin(s.angle) * s.life;
    const tailX = headX - Math.cos(s.angle) * s.length;
    const tailY = headY - Math.sin(s.angle) * s.length;

    const grad = ctx.createLinearGradient(tailX, tailY, headX, headY);
    grad.addColorStop(0, 'rgba(201, 169, 110, 0)');
    grad.addColorStop(1, `rgba(255, 255, 255, ${s.opacity})`);

    ctx.beginPath();
    ctx.moveTo(tailX, tailY);
    ctx.lineTo(headX, headY);
    ctx.strokeStyle = grad;
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    stars.forEach((star) => {
      star.update();
      star.draw();
    });
    maybeCreateShootingStar();
    drawShootingStar();
    requestAnimationFrame(animate);
  }

  requestAnimationFrame(animate);
</script>
