---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getPublications, getPresentations } from '../lib/researchmap';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const publications = await getPublications();
const presentations = await getPresentations();
---

<BaseLayout title="Research" description="研究概要・論文リスト・学会発表">
  <PageHeader title="Research" subtitle={t('section.publications')} />

  <section class="bg-ivory py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <!-- Research Overview -->
      <div class="mb-16 reveal">
        <h3 class="font-heading text-xl text-dark-navy mb-4">
          {lang === 'ja' ? '研究概要' : 'Research Overview'}
        </h3>
        <p class="text-sm text-text-subtle leading-relaxed">
          {lang === 'ja'
            ? '化学反応がどのように進むかの「地図」（反応経路地図）を比較するための新しい方法を研究しています。従来の手法が特定のポイントのみに注目するのに対し、この研究では反応経路全体のつながりを反映できる点が特長です。数学のトポロジー（位相幾何学）を活用し、「つながり」と「循環」を定量化することで、最終的には原子組成から分子の性質を分類・予測することを目指しています。'
            : 'My research develops new methods to compare "maps" of chemical reactions (reaction route maps). Unlike conventional methods that focus only on specific points, this approach reflects the connectivity of entire reaction pathways. By leveraging topology from mathematics, I quantify "connectivity" and "cycles" to ultimately classify and predict molecular properties from atomic composition.'}
        </p>
      </div>

      <!-- Publications -->
      <div class="mb-16 reveal">
        <h3 class="font-heading text-xl text-dark-navy mb-6 pb-3 border-b border-dark-navy/10">
          {lang === 'ja' ? '論文' : 'Publications'}
        </h3>
        <p class="text-[10px] text-text-muted mb-4 tracking-[1px]">
          {lang === 'ja'
            ? `researchmap より自動取得（${publications.length}件）`
            : `Auto-fetched from researchmap (${publications.length} items)`}
        </p>
        <div class="space-y-4">
          {publications.map((pub) => (
            <div class="bg-white p-5 border-l-[3px] border-gold">
              <h4 class="text-sm font-bold text-dark-navy leading-snug">
                {(lang === 'ja' ? pub.title.ja : pub.title.en) || pub.title.en || pub.title.ja}
              </h4>
              <p class="text-[11px] text-text-muted mt-2">
                {pub.journal}
                {pub.volume && `, ${pub.volume}`}
                {pub.number && `(${pub.number})`}
                {pub.startPage && `, ${pub.startPage}`}
                {pub.endPage && `–${pub.endPage}`}
                {` (${pub.year})`}
              </p>
              {pub.doi && (
                <a
                  href={`https://doi.org/${pub.doi}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block mt-2 text-[10px] tracking-[1px] text-gold hover:text-gold-light transition-colors"
                >
                  DOI →
                </a>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Presentations -->
      <div class="reveal">
        <h3 class="font-heading text-xl text-dark-navy mb-6 pb-3 border-b border-dark-navy/10">
          {lang === 'ja' ? '学会発表' : 'Presentations'}
        </h3>
        <div class="space-y-3">
          {presentations.map((pres) => (
            <div class="bg-white p-4 border-l-[3px] border-dark-navy/20">
              <h4 class="text-sm font-bold text-dark-navy leading-snug">
                {(lang === 'ja' ? pres.title.ja : pres.title.en) || pres.title.en || pres.title.ja}
              </h4>
              <p class="text-[11px] text-text-muted mt-1">
                {pres.event}, {pres.year}
              </p>
              <div class="flex gap-2 mt-2">
                {pres.isInternational && (
                  <span class="text-[9px] tracking-[1px] px-2 py-0.5 bg-gold/10 text-gold border border-gold/20">
                    INTERNATIONAL
                  </span>
                )}
                {pres.isInvited && (
                  <span class="text-[9px] tracking-[1px] px-2 py-0.5 bg-dark-navy/10 text-dark-navy border border-dark-navy/20">
                    INVITED
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- researchmap link -->
      <div class="mt-12 text-center reveal">
        <a
          href="https://researchmap.jp/burai"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block text-[11px] tracking-[2px] text-gold hover:text-gold-light transition-colors border-b border-gold/30 pb-1"
        >
          {lang === 'ja' ? 'researchmap で全業績を見る →' : 'View all on researchmap →'}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
